# MongoDB
MONGO_URI=mongodb://localhost:27017/clearclaim

# Auth / JWT
SECRET_KEY=change-me-to-a-random-secret-key

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# TinyFish API key
TINYFISH_API_KEY=your-tinyfish-api-key-here

# AgentMail (email notifications)
AGENTMAIL_API_KEY=your-agentmail-api-key-here
AGENTMAIL_FROM_EMAIL=noreply@clearclaim.ai
